NSPO_API_ADDR=:8080
NSPO_DATA_DIR=./data/derived
NSPO_REVIEW_STORE=./data/runtime/reviews.json
NSPO_HTTP_TIMEOUT_SECONDS=20
NSPO_USER_AGENT=nspo-research/0.1
NSPO_RATE_LIMIT_SECONDS=1
# Optional PostgreSQL backend (leave empty to use file store).
NSPO_DATABASE_URL=

# Taiwan NUSC — set from the current official open-data dataset pages (never commit live URLs).
NSPO_TW_NUSC_RADIATION_URL=
NSPO_TW_NUSC_STATIONS_URL=
NSPO_TW_NUSC_MONTHLY_URL=

# Korea public APIs (data.go.kr / KHNP / KORAD) — service key via environment only.
NSPO_KOREA_SERVICE_KEY=
NSPO_KHNP_WEATHER_URL=
NSPO_KHNP_OPERATION_STATUS_URL=
NSPO_KORAD_RADIATION_URL=
NSPO_KORAD_WEATHER_URL=
NSPO_KORAD_SEISMIC_URL=
NSPO_KORAD_WASTE_URL=
NSPO_KORAD_SILO_URL=
